# Z.ai API
ZAI_API_KEY=your-api-key-here
ZAI_API_URL=https://api.z.ai/api/coding/paas/v4/chat/completions
ZAI_MODEL=glm-5

# JWT
JWT_SECRET=change-me-in-production

# OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email SMTP
SMTP_USER=
SMTP_PASSWORD=

# Payment (PortOne)
PORTONE_IMP_KEY=
PORTONE_IMP_SECRET=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
FRONTEND_URL=http://192.168.0.9:8000
# Additional CORS origins (comma-separated) — GitHub Pages, staging URLs
# NOTE: *.github.io and *.trycloudflare.com origins are auto-allowed in production (ZEMA-2620)
EXTRA_CORS_ORIGINS=https://zemyalpha.github.io

# DB
DATABASE_PATH=./taronyang.db
