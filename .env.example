# Z.ai API
ZAI_API_KEY=your-api-key-here
ZAI_API_URL=https://api.z.ai/api/coding/paas/v4/chat/completions
ZAI_MODEL=glm-5

# JWT
JWT_SECRET=change-me-in-production

# OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email SMTP
SMTP_USER=
SMTP_PASSWORD=

# Payment (PortOne)
PORTONE_IMP_KEY=
PORTONE_IMP_SECRET=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
FRONTEND_URL=http://192.168.0.9:8000
# Additional CORS origins (comma-separated) — GitHub Pages, staging URLs
# NOTE: Only explicit origins are allowed in production (ZEMA-2715 removed wildcard patterns).
# Wildcards like *.github.io are NOT auto-allowed — list each origin explicitly below.
EXTRA_CORS_ORIGINS=https://zemyalpha.github.io

# DB
DATABASE_PATH=./taronyang.db

# GitHub Pages build-time SEO/analytics injection (ZEMA-2794)
# When set, the gh-pages build script injects these into all HTML <head>.
# Leave empty for no-op (build output unchanged).
GSC_VERIFICATION_CODE=
GA4_MEASUREMENT_ID=
